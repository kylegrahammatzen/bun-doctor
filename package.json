{
  "name": "bun-doctor",
  "version": "0.0.3",
  "description": "Diagnose Node-to-Bun migration readiness for JavaScript and TypeScript projects",
  "keywords": [
    "bun",
    "bun-doctor",
    "migration",
    "diagnostics",
    "nodejs",
    "typescript",
    "cli"
  ],
  "homepage": "https://github.com/kylegrahammatzen/bun-doctor#readme",
  "bugs": {
    "url": "https://github.com/kylegrahammatzen/bun-doctor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylegrahammatzen/bun-doctor.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "bun-doctor": "bin/bun-doctor.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "docs",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "bun run build",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "bun run typecheck && bun test && bun run build",
    "docs:refresh": "bun run scripts/refresh-bun-docs.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^24.10.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "smol-toml": "^1.6.1"
  }
}
